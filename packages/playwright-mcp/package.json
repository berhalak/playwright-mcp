{
  "name": "@berhalak/playwright-mcp",
  "version": "0.1.0",
  "description": "Playwright MCP server with multi-session support",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/berhalak/playwright-mcp.git"
  },
  "homepage": "https://github.com/berhalak/playwright-mcp",
  "engines": {
    "node": ">=18"
  },
  "author": {
    "name": "berhalak"
  },
  "license": "Apache-2.0",
  "scripts": {
    "lint": "node update-readme.js",
    "test": "playwright test",
    "ctest": "playwright test --project=chrome",
    "ftest": "playwright test --project=firefox",
    "wtest": "playwright test --project=webkit",
    "dtest": "MCP_IN_DOCKER=1 playwright test --project=chromium-docker",
    "build": "echo OK",
    "npm-publish": "npm run lint && npm run test && npm publish --access public"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./index.d.ts",
      "default": "./index.js"
    }
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "playwright": "1.59.0-alpha-1771104257000",
    "playwright-core": "1.59.0-alpha-1771104257000"
  },
  "bin": {
    "playwright-mcp": "cli.js"
  }
}
